# Copy to defaults.env, fill in. defaults.env is gitignored.

# ---- Blender / Infinigen -------------------------------------------------
BLENDER_BIN=/opt/blender-4.2.0-linux-x64/blender
INFINIBENCH_ROOT=/home/<you>/infinibench

# ---- Agentic LLM (optional; omit to use deterministic constraints) -------
INFINIBENCH_AGENTIC_LLM=gemini
INFINIBENCH_GEMINI_MODEL=gemini-3-flash-preview
GEMINI_API_KEY=

# ---- Scene generation defaults ------------------------------------------
SEED=42
SCENE_DESCRIPTION="Small bedroom with high occupancy"
GIN_CONFIG=fast_solve

# ---- Output root --------------------------------------------------------
WORK_DIR=/tmp/infinibench_run

# ---- Unreal Engine 5 (Linux UE binary; on WSL set to /mnt/.../UnrealEditor-Cmd.exe) ----
UE_EDITOR_CMD=/opt/UE_5.7/Engine/Binaries/Linux/UnrealEditor-Cmd
UE_PROJECT=/home/<you>/UE5Projects/InfiniBench/InfiniBench.uproject
UE_MAP_ASSET=/Game/InfiniBench/Maps/DefaultMap
UE_SEQ_ASSET=/Game/InfiniBench/S_Traj
UE_FOCAL_LENGTH=10
